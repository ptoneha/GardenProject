<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.agriculture.mapper.BusTaskLandMapper">

    <resultMap type="BusTaskLand" id="BusTaskLandResult">
        <result property="taskId" column="task_id" />
        <result property="landId" column="land_id" />
    </resultMap>

    <sql id="selectBusTaskLandVo">
        select task_id, land_id from bus_task_land
    </sql>

    <select id="selectBusTaskLandList" parameterType="BusTaskLand" resultMap="BusTaskLandResult">
        <include refid="selectBusTaskLandVo"/>
        <where>
            <if test="taskId != null">and task_id = #{taskId}</if>
            <if test="landId != null">and land_id = #{landId}</if>
        </where>
    </select>

    <select id="selectBusTaskLandByTaskId" parameterType="Long" resultMap="BusTaskLandResult">
        <include refid="selectBusTaskLandVo"/>
        where task_id = #{taskId}
        limit 1
    </select>

    <select id="selectBusTaskLandListByTaskId" parameterType="Long" resultMap="BusTaskLandResult">
        <include refid="selectBusTaskLandVo"/>
        where task_id = #{taskId}
        order by land_id
    </select>

    <insert id="insertBusTaskLand" parameterType="BusTaskLand">
        insert into bus_task_land
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null">task_id,</if>
            <if test="landId != null">land_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskId != null">#{taskId},</if>
            <if test="landId != null">#{landId},</if>
        </trim>
    </insert>

    <update id="updateBusTaskLand" parameterType="BusTaskLand">
        update bus_task_land
        <trim prefix="SET" suffixOverrides=",">
            <if test="landId != null">land_id = #{landId},</if>
        </trim>
        where task_id = #{taskId}
    </update>

    <delete id="deleteBusTaskLandByTaskId" parameterType="Long">
        delete from bus_task_land where task_id = #{taskId}
    </delete>

    <delete id="deleteBusTaskLandByTaskIds" parameterType="String">
        delete from bus_task_land where task_id in
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>
</mapper>
